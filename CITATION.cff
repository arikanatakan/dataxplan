    given-names: Atakan
version: 0.1.0
date-released: 2026-06-17
license: MIT
repository-code: "https://github.com/arikanatakan/dataxplan"
url: "https://github.com/arikanatakan/dataxplan"
keywords:
  - postgresql
  - explain
  - query-plan
  - performance
  - query-optimization
  - database
  - sql
